# Copier vers .env et renseigner les valeurs (ne jamais committer .env)

# IMAP
IMAP_USER=
IMAP_PASSWORD=
IMAP_HOST=mail.mediasoftci.net
IMAP_PORT=993
# Dossier à analyser (ex. INBOX, ou "[Gmail]/All Mail" selon le fournisseur)
IMAP_FOLDER=INBOX
# true = SSL (993), false = tentative non-SSL si échec
IMAP_USE_SSL=true

# Clés API (résumé assistant)
OPENAI_API_KEY=
GEMINI_API_KEY=
# Alternative acceptée par le code existant :
# GOOGLE_API_KEY=

# ML local : false pour désactiver transformers + spaCy (sentiment/NER par mots-clés + LLM uniquement)
# Recommandé en production : false — évite un chargement de modèles coûteux et
# accélère fortement l'analyse (moins de risque de timeout).
EMAIL_ANALYZER_USE_LOCAL_ML=true

# Timeout du client LLM (secondes). Volontairement < au timeout de passerelle
# (Nginx / zrok) pour échouer vite plutôt que de tenir le worker trop longtemps.
LLM_TIMEOUT_SECONDS=60

# Redis : store de jobs (/api/analyze) + queue arq. Requis pour lancer l'API
# et le worker arq (voir email_analyzer/analysis_tasks.py).
REDIS_URL=redis://localhost:6379/0

# Cache et analyse
EMAIL_ANALYZER_CACHE_FILE=email_analysis_cache.json
EMAIL_ANALYZER_MAX_DEEP_EMAILS=20
# 1 = recherche IMAP OR SUBJECT/TEXT pour limiter les messages téléchargés (plus rapide). 0 = tout SINCE

# --- SaaS multi-tenant ---
# Si DATABASE_URL est défini : API en mode SaaS (JWT, tenants, IMAP par org). Sinon : mode legacy (.env IMAP seul).
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/email_analyzer
# JWT_SECRET=   # obligatoire en SaaS — python -c "import secrets; print(secrets.token_urlsafe(48))"
# ENCRYPTION_KEY=   # Fernet — python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Générer ENCRYPTION_KEY : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TRIAL_ANALYSES_LIMIT=5
# EMAIL_ANALYZER_CACHE_DIR=.cache_tenants
# Origine(s) autorisée(s) pour le CORS (scheme + host + port, sans slash final).
# Plusieurs origines possibles, séparées par des virgules.
# FRONTEND_ORIGIN=https://votre-frontend.example.com,https://www.votre-frontend.example.com
# APP_PUBLIC_URL=https://votre-api.example.com
# CINETPAY_API_KEY=
# CINETPAY_SITE_ID=
# CINETPAY_SECRET_KEY=
# CINETPAY_DEFAULT_CUSTOMER_PHONE=+2250500000000
# CINETPAY_DEFAULT_CUSTOMER_COUNTRY=CI

# --- Gmail OAuth2 ---
# Create a project at https://console.cloud.google.com/, enable the Gmail API,
# and add an OAuth 2.0 Client ID (Web application type).
# The redirect URI must be: APP_PUBLIC_URL/api/oauth/gmail/callback
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# --- Outlook OAuth2 (Microsoft identity platform) ---
# Register an app at https://portal.azure.com/ (Azure Active Directory > App
# registrations), add a client secret, and enable Mail.Read + User.Read +
# offline_access delegated permissions.
# The redirect URI must be: APP_PUBLIC_URL/api/oauth/outlook/callback
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=